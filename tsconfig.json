    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "skipLibCheck": true,
        "types": [
            "vite/client"
        ],
        "esModuleInterop": true,
        "allowJs": true
    },
    "include": [
        "resources/js/**/*.ts"
    ]
}